{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.ai/schemas/current_pe.schema.json",
  "title": "Current PE State",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "pe_id",
    "objective",
    "branch",
    "baseline",
    "lane",
    "implementer",
    "validator",
    "current_state",
    "file_scope",
    "runtime_bootstrap_allowlist",
    "required_rules",
    "phase_1_gates",
    "tests",
    "rollback",
    "hard_stops",
    "live_dispatch_statement",
    "runtime_bootstrap_policy"
  ],
  "properties": {
    "pe_id": { "type": "string" },
    "objective": { "type": "string" },
    "branch": { "type": "string" },
    "baseline": { "type": "string" },
    "lane": { "type": "string" },
    "implementer": { "type": "string" },
    "validator": { "type": "string" },
    "current_state": { "type": "string" },
    "file_scope": { "type": "array", "items": { "type": "string" } },
    "runtime_bootstrap_allowlist": { "type": "array", "items": { "type": "string" } },
    "required_rules": { "type": "array", "items": { "type": "string" } },
    "phase_1_gates": { "type": "array", "items": { "type": "string" } },
    "tests": { "type": "array", "items": { "type": "string" } },
    "rollback": { "type": "string" },
    "hard_stops": { "type": "array", "items": { "type": "string" } },
    "live_dispatch_statement": { "type": "string" },
    "runtime_bootstrap_policy": { "type": "string" }
  }
}
