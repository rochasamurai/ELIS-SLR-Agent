{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elis-slr-agent/schemas/plan_schema.json",
  "title": "ELIS PE Plan",
  "description": "Schema for a JSON-format PE execution plan loadable by plan_loader.py.",
  "type": "object",
  "required": ["release", "base_branch", "pes"],
  "additionalProperties": false,
  "properties": {
    "release": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable release name."
    },
    "base_branch": {
      "type": "string",
      "minLength": 1,
      "description": "Git branch that all PE feature branches target (e.g. 'main')."
    },
    "plan_file": {
      "type": "string",
      "description": "Optional: filename of the source plan document."
    },
    "pes": {
      "type": "array",
      "minItems": 1,
      "description": "Ordered list of PE definitions.",
      "items": {
        "$ref": "#/$defs/pe"
      }
    }
  },
  "$defs": {
    "pe": {
      "type": "object",
      "required": [
        "id",
        "domain",
        "depends_on",
        "implementer",
        "validator",
        "acceptance_criteria"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^PE-[A-Z]+-[0-9]+$",
          "description": "Unique PE identifier, e.g. PE-AUTO-09."
        },
        "domain": {
          "type": "string",
          "minLength": 1,
          "description": "Functional domain label, e.g. infra, slr."
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^PE-[A-Z]+-[0-9]+$"
          },
          "description": "IDs of PEs that must be merged before this one may start."
        },
        "implementer": {
          "type": "string",
          "minLength": 1,
          "description": "Agent ID for the Implementer role, e.g. infra-impl-claude."
        },
        "validator": {
          "type": "string",
          "minLength": 1,
          "description": "Agent ID for the Validator role, e.g. infra-val-codex."
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "List of acceptance criteria strings."
        },
        "title": {
          "type": "string",
          "description": "Optional short title."
        }
      }
    }
  }
}
