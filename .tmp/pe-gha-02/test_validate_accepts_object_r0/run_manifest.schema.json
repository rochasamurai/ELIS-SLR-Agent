{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:elis:run-manifest:v2",
  "title": "ELIS Run Manifest",
  "description": "Run-level sidecar manifest for ELIS pipeline stages.",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "stage",
    "source",
    "repo_commit_sha",
    "config_hash",
    "started_at",
    "finished_at",
    "timestamp_utc",
    "record_count",
    "input_paths",
    "output_path",
    "model_family",
    "model_identifier",
    "model_version_snapshot",
    "routing_policy_version",
    "search_config_schema_version",
    "elis_package_version",
    "adapter_versions",
    "tool_versions"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "2.0"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "stage": {
      "type": "string",
      "enum": ["harvest", "merge", "dedup", "screen", "validate"]
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "repo_commit_sha": {
      "type": "string",
      "minLength": 7
    },
    "commit_sha": {
      "type": "string",
      "minLength": 7,
      "description": "Deprecated alias retained for backward compatibility."
    },
    "config_hash": {
      "type": "string",
      "pattern": "^sha256:.+"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time"
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time"
    },
    "record_count": {
      "type": "integer",
      "minimum": 0
    },
    "input_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "output_path": {
      "type": "string",
      "minLength": 1
    },
    "model_family": {
      "type": ["string", "null"]
    },
    "model_family_justification": {
      "type": "string",
      "minLength": 1
    },
    "model_identifier": {
      "type": ["string", "null"]
    },
    "model_identifier_justification": {
      "type": "string",
      "minLength": 1
    },
    "model_version_snapshot": {
      "type": ["string", "null"]
    },
    "routing_policy_version": {
      "type": "string",
      "minLength": 1
    },
    "search_config_schema_version": {
      "type": "string",
      "minLength": 1
    },
    "elis_package_version": {
      "type": "string",
      "minLength": 1
    },
    "adapter_versions": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "tool_versions": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "model_family": {
            "type": "null"
          }
        }
      },
      "then": {
        "required": ["model_family_justification"]
      }
    },
    {
      "if": {
        "properties": {
          "model_identifier": {
            "type": "null"
          }
        }
      },
      "then": {
        "required": ["model_identifier_justification"]
      }
    }
  ],
  "additionalProperties": false
}
